# Supabase — pegue em https://app.supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Sessao do morador (cookie assinado). Gere com: openssl rand -hex 32
SESSION_SECRET=trocar_por_uma_string_aleatoria_de_64_chars

# Admin (login simples)
ADMIN_EMAIL=admin@condo.com
ADMIN_PASSWORD=trocar_senha_forte

# Branding (aparece no header)
NEXT_PUBLIC_CONDO_NAME=Meu Condomínio
